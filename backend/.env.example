# Copy to .env and edit. NEVER commit the real .env.
# Generate a strong key:  python -c "import secrets; print(secrets.token_urlsafe(48))"
WISHBOX_SECRET_KEY=change-me-to-a-long-random-string
WISHBOX_ENV=development            # development | production
WISHBOX_DATABASE_URL=sqlite:///./wishbox.db
WISHBOX_ACCESS_TOKEN_MINUTES=30
WISHBOX_REFRESH_TOKEN_DAYS=14
WISHBOX_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional: plug an LLM provider for AI gift suggestions (left blank = local engine used)
WISHBOX_LLM_API_KEY=

# --- Payments. Default 'mock' = local offline gateway. Set 'razorpay' + keys to go live. ---
WISHBOX_PAYMENT_PROVIDER=mock        # mock | razorpay
WISHBOX_RAZORPAY_KEY_ID=
WISHBOX_RAZORPAY_KEY_SECRET=

# --- Tax / GST ---
WISHBOX_GST_PERCENT=18
WISHBOX_GST_INCLUSIVE=true
WISHBOX_STORE_GSTIN=27AAAAA0000A1Z5

# --- Email (blank => console + outbox only) ---
WISHBOX_SMTP_HOST=
WISHBOX_SMTP_PORT=587
WISHBOX_SMTP_USER=
WISHBOX_SMTP_PASSWORD=
WISHBOX_EMAIL_FROM=WishBox <no-reply@wishbox.local>

# --- SMS via Twilio (blank => console + outbox only) ---
WISHBOX_TWILIO_ACCOUNT_SID=
WISHBOX_TWILIO_AUTH_TOKEN=
WISHBOX_TWILIO_FROM_NUMBER=

# --- Background worker (reminders + outbox dispatch) ---
WISHBOX_ENABLE_WORKER=true
WISHBOX_WORKER_INTERVAL_SECONDS=60
WISHBOX_APP_BASE_URL=http://localhost:5173
